# =============================================================================
# LRA Vision Package - Get Camera Device Service
# Service to query available camera devices
# ROS2 Jazzy Jalisco
# =============================================================================

# Request
# No parameters needed - returns all available cameras
---
# Response

# Success flag
bool success

# Status message
string message

# Number of cameras found
int32 num_cameras

# Camera device paths (e.g., /dev/video0, /dev/video2)
string[] device_paths

# Camera names
string[] camera_names

# Camera capabilities
bool[] is_capture_devices
bool[] is_output_devices

# Supported resolutions (flattened: width1, height1, width2, height2, ...)
int32[] resolutions